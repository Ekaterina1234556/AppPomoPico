        BoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            Label:
                text: root.anim_name + ("  [публичная]" if root.is_public else "")
                halign: "left"
                font_size: dp(14)
                color: 1, 1, 1, 1
                text_size: self.width, None
            Label:
                text: "Теги: " + root.anim_tags if root.anim_tags else "Без тегов"
                halign: "left"
                font_size: dp(10)
                color: 0.65, 0.68, 0.75, 1
                text_size: self.width, None
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.edit()
            canvas.before:
                Color:
                    rgba: 0.22, 0.50, 0.85, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/edit.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40) if root.is_own and not root.is_public else 0
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            disabled: not (root.is_own and not root.is_public)
            on_release: root.publish()
            canvas.before:
                Color:
                    rgba: 0.80, 0.55, 0.10, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/publish.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.remove()
            canvas.before:
                Color:
                    rgba: 0.80, 0.22, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/delete.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2

<CharacterWidget>:

<AnimationFormScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(8)
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            ModernInput:
                id: ti_name
                hint_text: "Название анимации"
                text: root.name_init or ""
            Button:
                text: "Пуск"
                size_hint_x: None
                width: dp(75)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.play_animation()
                canvas.before:
                    Color:
                        rgba: 0.20, 0.65, 0.35, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
            Button:
                text: "Стоп"
                size_hint_x: None
                width: dp(75)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.stop_animation()
                canvas.before:
                    Color:
                        rgba: 0.70, 0.20, 0.20, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
        BoxLayout:
            size_hint_y: 1
            spacing: dp(10)
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.4
                canvas.before:
                    Color:
                        rgba: root.card_bg
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                CharacterWidget:
                    id: character
                    pose: root.current_pose
                BoxLayout:
                    size_hint_y: None
                    height: dp(36)
                    spacing: dp(8)
                    padding: dp(8)
                    Label:
                        text: "FPS: " + str(int(root.fps))
                        color: 1, 1, 1, 1
                        size_hint_x: None
                        width: dp(75)
                    Slider:
                        id: fps_slider
                        min: 1
                        max: 30
                        value: root.fps
                        step: 1
                        on_value: root.fps = int(self.value)
            ScrollView:
                do_scroll_x: False
                size_hint_x: 0.35
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: dp(4)
                    padding: dp(5)
                    Label:
                        text: "Суставы"
                        size_hint_y: None
                        height: dp(28)
                        bold: True
                        color: root.accent
                    JointSlider:
                        label: "Лев. плечо"
                        value: root.current_pose.get("left_shoulder", 0)
                        on_slider_value: root.current_pose["left_shoulder"] = args[1]
                    JointSlider:
                        label: "Лев. локоть"
                        value: root.current_pose.get("left_elbow", 0)
                        on_slider_value: root.current_pose["left_elbow"] = args[1]
                    JointSlider:
                        label: "Прав. плечо"
                        value: root.current_pose.get("right_shoulder", 0)
                        on_slider_value: root.current_pose["right_shoulder"] = args[1]
                    JointSlider:
                        label: "Прав. локоть"
                        value: root.current_pose.get("right_elbow", 0)
                        on_slider_value: root.current_pose["right_elbow"] = args[1]
                    JointSlider:
                        label: "Лев. бедро"
                        value: root.current_pose.get("left_hip", 0)
                        on_slider_value: root.current_pose["left_hip"] = args[1]
                    JointSlider:
                        label: "Лев. колено"
                        value: root.current_pose.get("left_knee", 0)
                        on_slider_value: root.current_pose["left_knee"] = args[1]
                    JointSlider:
                        label: "Прав. бедро"
                        value: root.current_pose.get("right_hip", 0)
                        on_slider_value: root.current_pose["right_hip"] = args[1]
                    JointSlider:
                        label: "Прав. колено"
                        value: root.current_pose.get("right_knee", 0)
                        on_slider_value: root.current_pose["right_knee"] = args[1]
            BoxLayout:
                orientation: "vertical"
                size_hint_x: 0.25
                Label:
                    text: "Кадры"
                    size_hint_y: None
                    height: dp(28)
                    bold: True
                    color: root.accent
                ScrollView:
                    GridLayout:
                        id: frames_grid
                        cols: 2
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)
                        padding: dp(4)
                BoxLayout:
                    size_hint_y: None
                    height: dp(38)
                    spacing: dp(4)
                    Button:
                        text: "+"
                        background_normal: ""
                        background_down: ""
                        background_color: 0, 0, 0, 0
                        color: 1, 1, 1, 1
                        on_release: root.add_frame()
                        canvas.before:
                            Color:
                                rgba: 0.20, 0.65, 0.35, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(5)]
                    Button:
                        text: "D"
                        background_normal: ""
                        background_down: ""
                        background_color: 0, 0, 0, 0
                        color: 1, 1, 1, 1
                        on_release: root.duplicate_frame()
                        canvas.before:
                            Color:
                                rgba: 0.28, 0.48, 0.75, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(5)]
                    Button:
                        text: "X"
                        background_normal: ""
                        background_down: ""
                        background_color: 0, 0, 0, 0
                        color: 1, 1, 1, 1
                        on_release: root.delete_frame()
                        canvas.before:
                            Color:
                                rgba: 0.75, 0.20, 0.20, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(5)]
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)
            Label:
                text: "Теги:"
                size_hint_x: None
                width: dp(55)
                color: 1, 1, 1, 1
            ScrollView:
                do_scroll_x: True
                do_scroll_y: False
                GridLayout:
                    id: tags_grid
                    cols: 1
                    size_hint_x: None
                    width: self.minimum_width
                    spacing: dp(5)
                    padding: dp(5)
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(15)
            ModernButton:
                text: "Отмена"
                bg_color: 0.35, 0.38, 0.45, 1
                on_release: root.cancel()
            ModernButton:
                text: "Сохранить"
                bg_color: root.accent
                on_release: root.save()

<JointSlider>:
    label: ""
    value: 0
    orientation: "vertical"
    size_hint_y: None
    height: dp(38)
    Label:
        text: root.label
        color: 1, 1, 1, 1
        halign: "left"
        text_size: self.width, None
        font_size: dp(10)
    Slider:
        id: slider
        min: -180
        max: 180
        value: root.value
        on_value: root._on_slider_change(self.value)

