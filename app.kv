<AnimationRow>:
    canvas.before:
        Color:
            rgba: root.accent[0], root.accent[1], root.accent[2], 0.08
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
    BoxLayout:
        padding: dp(12)
