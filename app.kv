#:import dp kivy.metrics.dp

<OnlineRoot>:
    bg_color: 0.06, 0.10, 0.18, 1
    accent:  0.29, 0.56, 0.89, 1
    card_bg: 0.10, 0.15, 0.24, 1
    surface: 0.14, 0.20, 0.30, 1
    text_primary: 1, 1, 1, 1
    text_secondary: 0.70, 0.78, 0.90, 1
    divider: 0.20, 0.26, 0.36, 1

<OfflineRoot>:
    bg_color: 0.08, 0.08, 0.10, 1
    accent:  0.91, 0.51, 0.17, 1
    card_bg: 0.13, 0.13, 0.15, 1
    surface: 0.18, 0.18, 0.20, 1
    text_primary: 1, 1, 1, 1
    text_secondary: 0.70, 0.70, 0.73, 1
    divider: 0.25, 0.25, 0.28, 1

<StartScreen>:
    canvas.before:
        Color:
            rgba: 0.04, 0.05, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(40)
        spacing: dp(30)
        Widget:
            size_hint_y: 0.25
        Label:
            text: "AppPomodoro"
            font_size: dp(40)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(60)
        Label:
            text: "Управление временем и задачами"
            font_size: dp(15)
            color: 0.6, 0.65, 0.75, 1
            size_hint_y: None
            height: dp(30)
        Widget:
            size_hint_y: 0.15
        BoxLayout:
            size_hint_y: None
            height: dp(100)
            spacing: dp(20)
            Widget:
                size_hint_x: 0.15
            StartModeButton:
                text: "Онлайн"
                bg_color: 0.18, 0.40, 0.72, 1
                on_release: root.go_online()
            StartModeButton:
                text: "Оффлайн"
                bg_color: 0.78, 0.42, 0.12, 1
                on_release: root.go_offline()
            Widget:
                size_hint_x: 0.15
        Widget:
            size_hint_y: 0.3

<StartModeButton@Button>:
    bg_color: 0.3, 0.3, 0.35, 1
    background_normal: ""
    background_down: ""
    background_color: self.bg_color
    color: 1, 1, 1, 1
    font_size: dp(22)
    bold: True
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]

<AuthScreen>:
    canvas.before:
        Color:
            rgba: 0.04, 0.05, 0.08, 1
        Rectangle:
            pos: self.pos
            size: self.size
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: "vertical"
            padding: dp(40)
            spacing: dp(15)
            size_hint_y: None
            height: self.minimum_height
            Widget:
                size_hint_y: None
                height: dp(50)
            Label:
                text: "Вход в аккаунт"
                font_size: dp(26)
                bold: True
                color: 0.29, 0.56, 0.89, 1
                size_hint_y: None
                height: dp(50)
            Label:
                text: "Введите данные для входа или регистрации"
                font_size: dp(14)
                color: 0.6, 0.65, 0.75, 1
                size_hint_y: None
                height: dp(30)
            Widget:
                size_hint_y: None
                height: dp(20)
            ModernInput:
                id: username
                hint_text: "Логин"
            ModernInput:
                id: email
                hint_text: "Email"
            ModernInput:
                id: password
                hint_text: "Пароль"
                password: True
            Label:
                text: root.error_text
                color: 1, 0.45, 0.45, 1
                size_hint_y: None
                height: dp(25) if root.error_text else 0
                font_size: dp(13)
            Label:
                text: root.info_text
                color: 0.45, 1, 0.55, 1
                size_hint_y: None
                height: dp(25) if root.info_text else 0
                font_size: dp(13)
            Widget:
                size_hint_y: None
                height: dp(15)
            BoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(15)
                ModernButton:
                    text: "Войти"
                    bg_color: 0.20, 0.55, 0.95, 1
                    on_release: root.do_login()
                ModernButton:
                    text: "Регистрация"
                    bg_color: 0.25, 0.70, 0.40, 1
                    on_release: root.do_register()
            ModernButton:
                text: "Назад"
                bg_color: 0.30, 0.32, 0.38, 1
                size_hint_y: None
                height: dp(50)
                on_release: root.go_back()
            Widget:
                size_hint_y: None
                height: dp(40)

<ModernInput@TextInput>:
    background_normal: ""
    background_active: ""
    background_color: 0.12, 0.15, 0.22, 1
    foreground_color: 1, 1, 1, 1
    hint_text_color: 0.45, 0.50, 0.60, 1
    multiline: False
    size_hint_y: None
    height: dp(50)
    padding: dp(15), dp(12)
    font_size: dp(15)
    write_tab: False
    cursor_blink: True
    use_bubble: True
    canvas.before:
        Color:
            rgba: 0.12, 0.15, 0.22, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]
        Color:
            rgba: 0.25, 0.30, 0.40, 1
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(6))
            width: dp(1)

<ModernButton@Button>:
    bg_color: 0.3, 0.3, 0.35, 1
    background_normal: ""
    background_down: ""
    background_color: self.bg_color
    color: 1, 1, 1, 1
    font_size: dp(15)
    bold: True
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

<AddButton@Button>:
    bg_color: 0.3, 0.3, 0.35, 1
    background_normal: ""
    background_down: ""
    background_color: self.bg_color
    color: 1, 1, 1, 1
    font_size: dp(13)
    bold: True
    size_hint_y: None
    height: dp(40)
    canvas.before:
        Color:
            rgba: self.bg_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(6)]

<SideMenu>:
    size_hint: None, 1
    width: dp(280)
    x: -self.width if not root.is_open else 0
    canvas.before:
        Color:
            rgba: 0.06, 0.08, 0.12, 1
        Rectangle:
            pos: self.pos
            size: self.size
        Color:
            rgba: 0.20, 0.25, 0.35, 1
        Line:
            points: [self.right, self.y, self.right, self.top]
            width: dp(1)
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: "vertical"
            padding: dp(12)
            spacing: dp(4)
            size_hint_y: None
            height: self.minimum_height
            
            # --- Всегда видны ---
            MenuItem:
                icon: "icons/home.png"
                text: "Главная"
                on_release: root.main_screen.open_section("home") if root.main_screen else None
            MenuItem:
                icon: "icons/work.png"
                text: "Начать работу"
                on_release: root.main_screen.open_section("work") if root.main_screen else None
            MenuItem:
                icon: "icons/tasks.png"
                text: "Задачи"
                on_release: root.main_screen.open_section("tasks") if root.main_screen else None
            MenuItem:
                icon: "icons/alarms.png"
                text: "Будильники"
                on_release: root.main_screen.open_section("alarms") if root.main_screen else None
            MenuItem:
                icon: "icons/animations.png"
                text: "Анимации"
                on_release: root.main_screen.open_section("animations") if root.main_screen else None
            MenuItem:
                icon: "icons/sounds.png"
                text: "Звуки"
                on_release: root.main_screen.open_section("sounds") if root.main_screen else None
            MenuItem:
                icon: "icons/settings.png"
                text: "Настройки"
                on_release: root.main_screen.open_section("settings") if root.main_screen else None
            
            # --- Отступ ---
            Widget:
                size_hint_y: None
                height: dp(20)
            
            # --- Только в онлайн-режиме ---
            MenuItem:
                icon: "icons/library.png"
                text: "Библиотека"
                size_hint_y: None
                height: dp(46) if root.is_online else 0
                opacity: 1 if root.is_online else 0
                disabled: not root.is_online
                on_release: root.main_screen.open_section("library") if root.main_screen and root.is_online else None
            MenuItem:
                icon: "icons/logout.png"
                text: "Выйти"
                size_hint_y: None
                height: dp(46) if root.is_online else 0
                opacity: 1 if root.is_online else 0
                disabled: not root.is_online
                on_release: root.logout() if root.is_online else None

                
<MenuItem@Button>:
    icon: ""
    background_normal: ""
    background_down: ""
    background_color: 0, 0, 0, 0
    color: 1, 1, 1, 1
    size_hint_y: None
    height: dp(46)
    BoxLayout:
        padding: dp(12), 0
        spacing: dp(14)
        Image:
            source: root.icon
            fit_mode: "contain"
            size_hint: None, None
            size: dp(22), dp(22)
        Label:
            text: root.text
            color: 1, 1, 1, 1
            halign: "left"
            text_size: self.width, None
            valign: "middle"
            font_size: dp(14)

<MainLayout>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            padding: dp(8)
            canvas.before:
                Color:
                    rgba: root.accent
                Rectangle:
                    pos: self.pos
                    size: self.size
            Button:
                text: ""
                size_hint_x: None
                width: dp(48)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                on_release: root.ids.side_menu.toggle()
                Image:
                    source: "icons/menu.png"
                    fit_mode: "contain"
                    size_hint: None, None
                    size: dp(26), dp(26)
                    pos: self.parent.x + (self.parent.width - dp(26)) / 2, self.parent.y + (self.parent.height - dp(26)) / 2
            Label:
                text: root.title
                font_size: dp(18)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
                valign: "middle"
            BoxLayout:
                size_hint_x: None
                width: dp(200)
                spacing: dp(10)
                Label:
                    text: "ОНЛАЙН" if root.is_online else "ОФФЛАЙН"
                    font_size: dp(11)
                    bold: True
                    color: 1, 1, 1, 0.9
                Label:
                    text: root.username if root.username else ""
                    font_size: dp(11)
                    color: 1, 1, 1, 0.75
                    size_hint_x: None
                    width: dp(120) if root.username else 0
        ScreenManager:
            id: content_sm
            Screen:
                name: "home"
                canvas.before:
                    Color:
                        rgba: root.bg_color
                    Rectangle:
                        pos: self.pos
                        size: self.size
                BoxLayout:
                    orientation: "vertical"
                    padding: dp(30)
                    spacing: dp(20)
                    Widget:
                        size_hint_y: 0.25
                    Label:
                        text: "Добро пожаловать"
                        font_size: dp(30)
                        bold: True
                        color: 1, 1, 1, 1
                        size_hint_y: None
                        height: dp(50)
                    Label:
                        text: "Режим: " + ("онлайн" if root.is_online else "оффлайн")
                        font_size: dp(15)
                        color: root.text_secondary
                        size_hint_y: None
                        height: dp(30)
                    Widget:
                        size_hint_y: 0.3
    SideMenu:
        id: side_menu
        is_online: root.is_online
        accent: root.accent
        main_screen: root

<WorkScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            Label:
                text: "Выберите задачу"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
        RelativeLayout:
            ScrollView:
                do_scroll_x: False
                RecycleView:
                    id: rv
                    viewclass: "WorkTaskRow"
                    RecycleBoxLayout:
                        default_size: None, dp(100)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: "vertical"
                        spacing: dp(8)
            Label:
                id: empty_label
                text: "Нет активных задач"
                color: root.text_secondary
                font_size: dp(15)
                opacity: 0

<WorkTaskRow>:
    canvas.before:
        Color:
            rgba: root.accent[0], root.accent[1], root.accent[2], 0.08
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
    BoxLayout:
        padding: dp(15)
        spacing: dp(15)
        BoxLayout:
            orientation: "vertical"
            spacing: dp(4)
            Label:
                text: root.task_name
                halign: "left"
                font_size: dp(16)
                bold: True
                color: 1, 1, 1, 1
                text_size: self.width, None
            Label:
                text: root.task_desc or ""
                halign: "left"
                font_size: dp(12)
                color: 0.70, 0.73, 0.80, 1
                text_size: self.width, None
            Label:
                text: root.task_date
                halign: "left"
                font_size: dp(11)
                color: 0.55, 0.60, 0.68, 1
                text_size: self.width, None
        Button:
            size_hint_x: None
            width: dp(56)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.open_task()
            canvas.before:
                Color:
                    rgba: 0.20, 0.65, 0.35, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]
            Image:
                source: "icons/play.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(24), dp(24)
                pos: self.parent.x + (self.parent.width - dp(24)) / 2, self.parent.y + (self.parent.height - dp(24)) / 2

<WorkTaskScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(15)
            size_hint_y: None
            height: self.minimum_height
            BoxLayout:
                size_hint_y: None
                height: dp(55)
                canvas.before:
                    Color:
                        rgba: root.card_bg
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                padding: dp(15)
                Label:
                    text: root.task_name
                    font_size: dp(20)
                    bold: True
                    color: 1, 1, 1, 1
                    halign: "center"
                    text_size: self.width - dp(30), None
                    valign: "middle"
            BoxLayout:
                size_hint_y: None
                height: dp(70)
                canvas.before:
                    Color:
                        rgba: root.card_bg
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                padding: dp(15)
                Label:
                    text: root.task_desc
                    font_size: dp(13)
                    color: 0.80, 0.83, 0.90, 1
                    halign: "center"
                    valign: "top"
                    text_size: self.width - dp(30), None
            BoxLayout:
                size_hint_y: None
                height: dp(25)
                Label:
                    text: root.task_date
                    font_size: dp(11)
                    color: 0.55, 0.60, 0.68, 1
                    halign: "right"
                    text_size: self.width, None
            BoxLayout:
                size_hint_y: None
                height: dp(180)
                canvas.before:
                    Color:
                        rgba: root.card_bg
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                padding: dp(10)
                CharacterWidget:
                    id: character
                    pose: root.animation_frames[root._play_idx] if root.animation_frames and root._play_idx < len(root.animation_frames) else {}
            BoxLayout:
                size_hint_y: None
                height: dp(80)
                canvas.before:
                    Color:
                        rgba: root.card_bg
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(8)]
                Label:
                    text: f"{int(root.remaining_seconds // 60):02d}:{int(root.remaining_seconds % 60):02d}"
                    font_size: dp(48)
                    bold: True
                    color: root.accent
            BoxLayout:
                size_hint_y: None
                height: dp(56)
                spacing: dp(12)
                Button:
                    text: "Старт" if not root.is_running else "Работает..."
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: dp(16)
                    bold: True
                    disabled: root.is_running
                    on_release: root.start_timer()
                    canvas.before:
                        Color:
                            rgba: 0.20, 0.65, 0.35, 1 if not root.is_running else 0.35, 0.38, 0.42
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
                Button:
                    text: "Пауза"
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: dp(16)
                    bold: True
                    disabled: not root.is_running
                    on_release: root.pause_timer()
                    canvas.before:
                        Color:
                            rgba: 0.80, 0.50, 0.15, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
            Button:
                text: "Назад"
                size_hint_y: None
                height: dp(48)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.go_back()
                canvas.before:
                    Color:
                        rgba: 0.28, 0.30, 0.36, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]

<TasksScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            Label:
                text: "Задачи"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
            AddButton:
                size_hint_x: None
                width: dp(110)
                bg_color: root.accent
                text: "Новая"
                on_release: root.open_task_form(None)
        RelativeLayout:
            ScrollView:
                do_scroll_x: False
                RecycleView:
                    id: rv
                    viewclass: "TaskRow"
                    RecycleBoxLayout:
                        default_size: None, dp(90)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: "vertical"
                        spacing: dp(6)
            Label:
                id: empty_label
                text: "Нет задач"
                color: root.text_secondary
                font_size: dp(14)
                opacity: 0

<TaskRow>:
    canvas.before:
        Color:
            rgba: root.accent[0], root.accent[1], root.accent[2], 0.08
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
    BoxLayout:
        padding: dp(12)
        spacing: dp(10)
        CheckBox:
            active: root.is_completed
            size_hint_x: None
            width: dp(40)
            on_active: root.toggle(self.active)
        BoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            Label:
                text: root.task_name
                halign: "left"
                color: 1, 1, 1, 1
                font_size: dp(14)
                bold: True
                text_size: self.width, None
            BoxLayout:
                size_hint_y: None
                height: dp(16)
                Label:
                    text: root.task_desc or ""
                    halign: "left"
                    font_size: dp(11)
                    color: 0.65, 0.68, 0.75, 1
                    text_size: self.width, None
                Label:
                    text: root.task_date
                    halign: "right"
                    font_size: dp(10)
                    color: 0.50, 0.55, 0.63, 1
                    size_hint_x: None
                    width: dp(130)
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.edit()
            canvas.before:
                Color:
                    rgba: 0.22, 0.50, 0.85, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/edit.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.remove()
            canvas.before:
                Color:
                    rgba: 0.80, 0.22, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/delete.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2

<TaskFormScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(15)
            size_hint_y: None
            height: self.minimum_height
            Label:
                text: "Новая задача" if root.task_id is None else "Редактирование"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(40)
                halign: "left"
                text_size: self.width, None
            ModernInput:
                id: ti_name
                hint_text: "Название задачи"
                text: root.name_init or ""
            ModernInput:
                id: ti_desc
                hint_text: "Описание"
                multiline: True
                height: dp(100)
                text: root.desc_init or ""
            ModernInput:
                id: ti_dur
                hint_text: "Длительность (минуты)"
                input_filter: "int"
                text: root.dur_init or ""
            Label:
                text: "Анимация"
                halign: "left"
                color: 0.75, 0.78, 0.85, 1
                size_hint_y: None
                height: dp(22)
                text_size: self.width, None
            Spinner:
                id: sp_animation
                text: root.animation_name_by_id.get(root.current_animation_id, "Без анимации")
                values: root.animation_options
                size_hint_y: None
                height: dp(50)
                background_normal: ""
                background_down: ""
                background_color: root.accent
                color: 1, 1, 1, 1
                canvas.before:
                    Color:
                        rgba: root.accent
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(15)
                ModernButton:
                    text: "Отмена"
                    bg_color: 0.35, 0.38, 0.45, 1
                    on_release: root.cancel()
                ModernButton:
                    text: "Сохранить"
                    bg_color: root.accent
                    on_release: root.save()

<AlarmsScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        BoxLayout:
            size_hint_y: None
            height: dp(45)
            Label:
                text: "Будильники"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
            AddButton:
                size_hint_x: None
                width: dp(110)
                bg_color: root.accent
                text: "Новый"
                on_release: root.open_alarm_form(None)
        RelativeLayout:
            ScrollView:
                do_scroll_x: False
                RecycleView:
                    id: rv
                    viewclass: "AlarmRow"
                    RecycleBoxLayout:
                        default_size: None, dp(85)
                        default_size_hint: 1, None
                        size_hint_y: None
                        height: self.minimum_height
                        orientation: "vertical"
                        spacing: dp(6)
            Label:
                id: empty_label
                text: "Нет будильников"
                color: root.text_secondary
                font_size: dp(14)
                opacity: 0

<AlarmRow>:
    canvas.before:
        Color:
            rgba: root.accent[0], root.accent[1], root.accent[2], 0.08
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(8)]
    BoxLayout:
        padding: dp(12)
        spacing: dp(10)
        BoxLayout:
            orientation: "vertical"
            spacing: dp(2)
            Label:
                text: root.alarm_name
                halign: "left"
                font_size: dp(15)
                color: 1, 1, 1, 1
                text_size: self.width, None
            Label:
                text: root.alarm_time + ("  " + root.alarm_date if root.alarm_date else "  ежедневно")
                halign: "left"
                font_size: dp(11)
                color: 0.65, 0.68, 0.75, 1
                text_size: self.width, None
        CheckBox:
            active: root.is_active
            size_hint_x: None
            width: dp(40)
            on_active: root.toggle(self.active)
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.edit()
            canvas.before:
                Color:
                    rgba: 0.22, 0.50, 0.85, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/edit.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.remove()
            canvas.before:
                Color:
                    rgba: 0.80, 0.22, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/delete.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2

<AlarmFormScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    ScrollView:
        do_scroll_x: False
        BoxLayout:
            orientation: "vertical"
            padding: dp(20)
            spacing: dp(15)
            size_hint_y: None
            height: self.minimum_height
            Label:
                text: "Новый будильник" if root.alarm_id is None else "Редактирование"
                font_size: dp(20)
                bold: True
                color: 1, 1, 1, 1
                size_hint_y: None
                height: dp(40)
                halign: "left"
                text_size: self.width, None
            ModernInput:
                id: ti_name
                hint_text: "Название"
                text: root.name_init or ""
            Label:
                text: "Время"
                halign: "left"
                color: 0.75, 0.78, 0.85, 1
                size_hint_y: None
                height: dp(22)
                text_size: self.width, None
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(10)
                Spinner:
                    id: sp_hour
                    text: root.time_init.split(":")[0] if ":" in root.time_init else "08"
                    values: [str(h).zfill(2) for h in range(24)]
                    background_normal: ""
                    background_down: ""
                    background_color: root.accent
                    color: 1, 1, 1, 1
                    canvas.before:
                        Color:
                            rgba: root.accent
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
                Label:
                    text: ":"
                    color: 1, 1, 1, 1
                    size_hint_x: None
                    width: dp(20)
                Spinner:
                    id: sp_minute
                    text: root.time_init.split(":")[1] if ":" in root.time_init else "00"
                    values: [str(m).zfill(2) for m in range(60)]
                    background_normal: ""
                    background_down: ""
                    background_color: root.accent
                    color: 1, 1, 1, 1
                    canvas.before:
                        Color:
                            rgba: root.accent
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(10)
                ModernInput:
                    id: ti_date
                    hint_text: "Дата (ГГГГ-ММ-ДД) или пусто"
                    text: root.date_init or ""
                Button:
                    text: "Сегодня"
                    size_hint_x: None
                    width: dp(100)
                    background_normal: ""
                    background_down: ""
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    on_release: root.set_today()
                    canvas.before:
                        Color:
                            rgba: root.accent
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(6)]
            Label:
                text: "Мелодия будильника"
                halign: "left"
                color: 0.75, 0.78, 0.85, 1
                size_hint_y: None
                height: dp(22)
                text_size: self.width, None
            Spinner:
                id: sp_sound
                text: root.sound_name_by_id.get(int(root.current_sound_id), "Стандартная")
                values: root.sound_options
                size_hint_y: None
                height: dp(50)
                background_normal: ""
                background_down: ""
                background_color: root.accent
                color: 1, 1, 1, 1
                canvas.before:
                    Color:
                        rgba: root.accent
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
            BoxLayout:
                size_hint_y: None
                height: dp(50)
                spacing: dp(15)
                ModernButton:
                    text: "Отмена"
                    bg_color: 0.35, 0.38, 0.45, 1
                    on_release: root.cancel()
                ModernButton:
                    text: "Сохранить"
                    bg_color: root.accent
                    on_release: root.save()

<AnimationsScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
