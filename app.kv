            Label:
                text: root.sound_name + ("  [публичный]" if root.is_public else "")
                halign: "left"
                font_size: dp(14)
                color: 1, 1, 1, 1
                text_size: self.width, None
            Label:
                text: "Теги: " + root.sound_tags if root.sound_tags else "Без тегов"
                halign: "left"
                font_size: dp(10)
                color: 0.65, 0.68, 0.75, 1
                text_size: self.width, None
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.edit()
            canvas.before:
                Color:
                    rgba: 0.22, 0.50, 0.85, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/edit.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40) if root.is_own and not root.is_public else 0
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            disabled: not (root.is_own and not root.is_public)
            on_release: root.publish()
            canvas.before:
                Color:
                    rgba: 0.80, 0.55, 0.10, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/publish.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2
        Button:
            size_hint_x: None
            width: dp(40)
            background_normal: ""
            background_down: ""
            background_color: 0, 0, 0, 0
            on_release: root.remove()
            canvas.before:
                Color:
                    rgba: 0.80, 0.22, 0.22, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(5)]
            Image:
                source: "icons/delete.png"
                fit_mode: "contain"
                size_hint: None, None
                size: dp(18), dp(18)
                pos: self.parent.x + (self.parent.width - dp(18)) / 2, self.parent.y + (self.parent.height - dp(18)) / 2

<SoundFormScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(10)
        spacing: dp(8)
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            ModernInput:
                id: ti_name
                hint_text: "Название мелодии"
                text: root.name_init or ""
            Label:
                text: "BPM:"
                size_hint_x: None
                width: dp(45)
                color: 1, 1, 1, 1
            ModernInput:
                id: ti_bpm
                text: str(int(root.bpm))
                input_filter: "int"
                size_hint_x: None
                width: dp(65)
                on_text_validate: root.bpm = int(self.text) if self.text.isdigit() else 120
            Button:
                text: "Пуск"
                size_hint_x: None
                width: dp(65)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.play_melody()
                canvas.before:
                    Color:
                        rgba: 0.20, 0.65, 0.35, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
            Button:
                text: "Стоп"
                size_hint_x: None
                width: dp(65)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.stop_melody()
                canvas.before:
                    Color:
                        rgba: 0.70, 0.20, 0.20, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
            Button:
                text: "X"
                size_hint_x: None
                width: dp(45)
                background_normal: ""
                background_down: ""
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_release: root.clear_grid()
                canvas.before:
                    Color:
                        rgba: 0.45, 0.28, 0.10, 1
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(6)]
        Label:
            text: "Кликайте по ячейкам, чтобы ставить ноты (C4..C5 x 32 шага)"
            size_hint_y: None
            height: dp(22)
            color: 0.65, 0.68, 0.75, 1
            font_size: dp(11)
            halign: "left"
            text_size: self.width, None
        ScrollView:
            do_scroll_x: True
            do_scroll_y: True
            GridLayout:
                id: piano_grid
                cols: 33
                size_hint: None, None
                width: dp(40) + 32 * dp(22)
                height: 13 * dp(24)
                spacing: dp(1)
                padding: dp(2)
        BoxLayout:
            size_hint_y: None
            height: dp(56)
            spacing: dp(8)
            Label:
                text: "Теги:"
                size_hint_x: None
                width: dp(55)
                color: 1, 1, 1, 1
            ScrollView:
                do_scroll_x: True
                do_scroll_y: False
                GridLayout:
                    id: tags_grid
                    cols: 1
                    size_hint_x: None
                    width: self.minimum_width
                    spacing: dp(5)
                    padding: dp(5)
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(15)
            ModernButton:
                text: "Отмена"
                bg_color: 0.35, 0.38, 0.45, 1
                on_release: root.cancel()
            ModernButton:
                text: "Сохранить"
                bg_color: root.accent
                on_release: root.save()

<ThemesScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        Label:
            text: "Выбор темы"
            font_size: dp(20)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(40)
            halign: "left"
            text_size: self.width, None
        ScrollView:
            GridLayout:
                id: grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)

<SettingsScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        Label:
            text: "Настройки"
            font_size: dp(20)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(40)
            halign: "left"
            text_size: self.width, None
        BoxLayout:
            size_hint_y: None
            height: dp(52)
            canvas.before:
                Color:
                    rgba: root.card_bg
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]
            padding: dp(15), 0
            Label:
                text: "Звук уведомлений"
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
            Switch:
                active: True
                size_hint_x: None
                width: dp(80)
        BoxLayout:
            size_hint_y: None
            height: dp(52)
            canvas.before:
                Color:
                    rgba: root.card_bg
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]
            padding: dp(15), 0
            Label:
                text: "Вибрация"
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
            Switch:
                active: False
                size_hint_x: None
                width: dp(80)
        BoxLayout:
            size_hint_y: None
            height: dp(52)
            canvas.before:
                Color:
                    rgba: root.card_bg
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(6)]
            padding: dp(15), 0
            Label:
                text: "Текущий режим: " + ("Онлайн" if root.parent and root.parent.is_online else "Оффлайн")
                color: 1, 1, 1, 1
                halign: "left"
                text_size: self.width, None
            ModernButton:
                text: "Изменить"
                bg_color: root.accent
                size_hint_x: None
                width: dp(120)
                on_release: root.change_mode()
        Widget:
<LibraryScreen>:
    canvas.before:
        Color:
            rgba: root.bg_color
        Rectangle:
            pos: self.pos
            size: self.size
    BoxLayout:
        orientation: "vertical"
        padding: dp(20)
        spacing: dp(15)
        Label:
            text: "Библиотека (онлайн)"
            font_size: dp(20)
            bold: True
            color: 1, 1, 1, 1
            size_hint_y: None
            height: dp(40)
            halign: "left"
            text_size: self.width, None
        Label:
            text: "Публичные анимации и звуки всех пользователей"
            color: 0.65, 0.68, 0.75, 1
            size_hint_y: None
            height: dp(22)
            halign: "left"
            text_size: self.width, None
        ScrollView:
            GridLayout:
                id: grid
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(10)
